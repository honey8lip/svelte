{
  "name": "svelte",
  "version": "4.0.0",
  "description": "Cybernetically enhanced web apps",
  "type": "module",
  "license": "MIT",
  "homepage": "https://svelte.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/sveltejs/svelte"
  },
  "bugs": {
    "url": "https://github.com/sveltejs/svelte/issues"
  },
  "scripts": {
    "build": "node scripts/build.js",
    "dev": "node scripts/build.js --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint src --ext .js,.ts",
    "format": "prettier --write src",
    "check": "tsc --noEmit",
    "changeset": "changeset",
    "release": "changeset publish"
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./src/index.js"
    },
    "./compiler": {
      "types": "./types/compiler.d.ts",
      "import": "./src/compiler/index.js"
    },
    "./store": {
      "types": "./types/store.d.ts",
      "import": "./src/store/index.js"
    },
    "./motion": {
      "types": "./types/motion.d.ts",
      "import": "./src/motion/index.js"
    },
    "./transition": {
      "types": "./types/transition.d.ts",
      "import": "./src/transition/index.js"
    },
    "./animate": {
      "types": "./types/animate.d.ts",
      "import": "./src/animate/index.js"
    },
    "./easing": {
      "types": "./types/easing.d.ts",
      "import": "./src/easing/index.js"
    },
    "./action": {
      "types": "./types/action.d.ts"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.26.2",
    "@types/node": "^20.4.5",
    "@typescript-eslint/eslint-plugin": "^6.2.1",
    "@typescript-eslint/parser": "^6.2.1",
    "acorn": "^8.10.0",
    "eslint": "^8.46.0",
    "prettier": "^3.0.1",
    "typescript": "^5.1.6",
    "vitest": "^0.34.1",
    "@vitest/ui": "^0.34.1"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "files": [
    "src",
    "types",
    "!src/**/*.test.*"
  ]
}
